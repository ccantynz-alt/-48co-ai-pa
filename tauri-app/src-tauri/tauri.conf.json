{
  "$schema": "https://raw.githubusercontent.com/nickelghost/tauri-v2-schemas/main/tauri.conf.json",
  "productName": "48co",
  "version": "1.0.0",
  "identifier": "nz.co.48co",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "48co — Voice to Text"
    },
    "windows": [
      {
        "label": "settings",
        "title": "48co Settings",
        "url": "/",
        "width": 480,
        "height": 600,
        "resizable": false,
        "visible": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "oneClick": true,
        "perMachine": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "signingIdentity": null
    },
    "iOS": {
      "developmentTeam": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ccantynz-alt/-48co-ai-pa/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
