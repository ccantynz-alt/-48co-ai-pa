# AlecRae Voice — Environment Variables
# Copy to .env.local (Next.js) and fill in your keys
# NEVER commit .env.local to git

# Claude API key (from console.anthropic.com)
CLAUDE_API_KEY=sk-ant-...

# OpenAI API key (from platform.openai.com)
OPENAI_API_KEY=sk-...

# Google OAuth Client ID (from console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Stripe (from dashboard.stripe.com/developers)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEAR_PRICE_ID=price_...
STRIPE_BIZ_PRICE_ID=price_...

# App URL (your domain)
NEXT_PUBLIC_APP_URL=https://alecrae.ai

# Admin secret (for promoting your own account to pro — pick any long random string)
ADMIN_SECRET=change-this-to-something-random-and-long

# Vercel Postgres (auto-set by Vercel when you link a database)
POSTGRES_URL=
